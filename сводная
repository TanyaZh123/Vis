function normalizeData(items) {
    const columnsSet = new Set();
    const tree = {};
    let periodRow = null;

    items.forEach(item => {
        const col  = item.keys?.[0];
        const lvl1 = item.keys?.[1];
        const lvl2 = item.keys?.[2];

        const start = item.values?.[0];
        const end   = item.values?.[1];
        let   value = item.values?.[2];

        if (!col) return;
        columnsSet.add(col);

        // первая строка — период цикла (если она вообще нужна)
        if (!lvl1 && !lvl2 && start != null && end != null) {
            periodRow = { col, start, end };
            return;
        }

        if (!lvl1 || !lvl2) return;

        // для этих строк берём не values[2], а keys[3]
        if (
            lvl2 === 'Начало периода' ||
            lvl2 === 'Конец периода' ||
            lvl2 === 'Продолжительность цикла'
        ) {
            value = item.keys?.[3];
        }

        if (!tree[lvl1]) tree[lvl1] = {};
        if (!tree[lvl1][lvl2]) tree[lvl1][lvl2] = {};
        tree[lvl1][lvl2][col] = value;
    });

    /* --- объединение "Расход" + "Расход Макс." как раньше, если нужно --- */
    Object.entries(tree).forEach(([lvl1, lvl2Map]) => {
        const base = lvl2Map["Расход"];
        const max  = lvl2Map["Расход Макс."];

        if (base && max) {
            Object.keys(base).forEach(col => {
                const v = base[col] ?? "";
                const m = max[col] ?? "";

                if (m !== "") {
                    base[col] = `${v} (${m})`;
                }
            });
            delete lvl2Map["Расход Макс."];
        }
    });

    return {
        columns: Array.from(columnsSet),
        tree,
        periodRow
    };
}



